{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ForecastRequest",
  "type": "object",
  "required": ["request_id", "target_month", "product_id", "product_context", "history", "current_context"],
  "properties": {
    "request_id": { "type": "string" },
    "target_month": { "type": "string", "format": "date" },
    "product_id": { "type": "string" },
    "tax_rate": { "type": "number" },
    "product_context": {
      "type": "object",
      "required": ["product_name", "category", "base_price"],
      "properties": {
        "product_name": { "type": "string" },
        "category": { "type": "string" },
        "base_price": { "type": "number" },
        "trend_strength": { "type": "number" },
        "seasonality_strength": { "type": "number" }
      }
    },
    "history": {
      "type": "object",
      "required": [
        "monthly_sales_lag_1",
        "monthly_sales_lag_2",
        "monthly_sales_lag_3",
        "monthly_sales_lag_4",
        "monthly_sales_lag_5",
        "monthly_sales_lag_6"
      ]
    },
    "current_context": {
      "type": "object",
      "required": ["average_price", "inventory_units", "promo_intensity"]
    }
  }
}

